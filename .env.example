# Trafiklab SL Transport API key
TRAFIKLAB_API_KEY=your_key_here

# Groq API key (free tier) for weekly digest
GROQ_API_KEY=your_key_here

# DuckDB path (local dev default; override in Azure to /app/data/...)
TRAFFIK_DB_PATH=data/traffik.duckdb

# Model artifacts directory
MODEL_DIR=model

# MLflow tracking URI
# Local: leave unset (defaults to sqlite:///mlflow.db)
# Azure prod: wasbs://mlflow@<account>.blob.core.windows.net/mlruns
# MLFLOW_TRACKING_URI=sqlite:///mlflow.db

# Azure Blob Storage (for model backups)
AZURE_STORAGE_CONNECTION_STRING=your_connection_string_here
AZURE_STORAGE_CONTAINER=model-backups

# Optional: Slack webhook for alerts
# SLACK_WEBHOOK=https://hooks.slack.com/services/...
